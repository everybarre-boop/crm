# 다른 Supabase 프로젝트로 바꿀 때만 이 파일을 `.env.local` 로 복사해 값을 채운다.
# (anon 키는 공개 키다. lib/supabase.ts 에 기본값이 하드코딩돼 있어 이 파일이 없어도 동작한다.)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────────
# [개발 도구 전용] Drizzle(drizzle-kit) 마이그레이션용 Postgres 접속 문자열.
# ⚠️ 전권 비밀번호가 포함된 비밀값이다(RLS 를 우회한다). 절대 커밋 금지, 클라이언트/번들에 쓰지 말 것.
#    (런타임 앱은 이 값을 쓰지 않는다. 오직 npm run db:* 명령에서만 쓴다.)
# ⚠️ 이 작업 폴더는 OneDrive 로 동기화된다. .env.local 을 이 폴더에 두면 DB 전권
#    비밀번호가 클라우드로 동기화된다. 가능하면 .env.local 을 동기화 밖 경로에 두고
#    drizzle.config.ts 의 config({ path }) 를 그 경로로 바꾸거나, 최소한 이 위험을 인지할 것.
#
# 값: Supabase 대시보드 → Connect → "Session pooler" 문자열을 복사해 [PASSWORD] 만 채운다.
#     (직접 연결 db.<ref>.supabase.co 는 IPv6 전용이라 대부분의 IPv4 환경에서 안 잡힌다.)
DATABASE_URL=postgresql://postgres.your-project:[PASSWORD]@aws-0-<REGION>.pooler.supabase.com:5432/postgres
# 직접 연결이 되는 환경(IPv4 add-on 등)에서만 아래 형식도 가능:
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres
